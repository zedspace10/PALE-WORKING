{
  "expo": {
    "name": "PALE",
    "slug": "pale",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stellara.pale",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PALE uses your location to show you which stars are visible above you tonight.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "PALE uses your location to show you which stars are visible above you tonight.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.stellara.pale",
      "versionCode": 1,
      "backgroundColor": "#000000",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://pale.space/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PALE uses your location to show you which stars are visible above you tonight."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://pale.space/"
      },
      "eas": {
        "projectId": "99b48305-73b0-4be6-8d07-91537694e0e0"
      }
    },
    "owner": "zedbs-organization"
  }
}
